{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}
{% block meta_description %}{{ product.desciption ? product.desciption|slice(0, 160) : 'Découvrez ' ~ product.name ~ ', miel artisanal de qualité.' }}{% endblock %}

{% block body %}

{# ===== BREADCRUMB ===== #}
<nav class="max-w-6xl mx-auto px-6 pt-6 pb-2 text-sm text-gray-400 flex items-center gap-2">
    <a href="{{ path('app_home') }}" class="hover:text-amber-600 transition-colors">Accueil</a>
    <span>/</span>
    <a href="{{ path('app_shop_index') }}" class="hover:text-amber-600 transition-colors">Nos miels</a>
    {% if product.category %}
        <span>/</span>
        <a href="{{ path('app_shop_index', {categorie: product.category.slug}) }}" class="hover:text-amber-600 transition-colors">
            {{ product.category.name }}
        </a>
    {% endif %}
    <span>/</span>
    <span class="text-gray-600 font-medium truncate max-w-xs">{{ product.name }}</span>
</nav>

{# ===== FICHE PRODUIT ===== #}
<section class="max-w-6xl mx-auto px-6 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">

        {# Image #}
        <div class="sticky top-24">
            {% if product.image %}
                <img src="/uploads/products/{{ product.image }}"
                     alt="{{ product.name }}"
                     class="w-full rounded-2xl border border-gray-200 shadow-sm object-cover aspect-square">
            {% else %}
                <div class="w-full aspect-square rounded-2xl bg-amber-50 border border-amber-100 flex items-center justify-center text-amber-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
            {% endif %}
        </div>

        {# Infos + achat #}
        <div class="space-y-6">

            {# En-tête #}
            <div>
                <div class="flex flex-wrap items-center gap-2 mb-3">
                    {% if product.category %}
                        <span class="text-xs font-semibold text-amber-600 uppercase tracking-wider bg-amber-50 px-2.5 py-1 rounded-full">
                            {{ product.category.name }}
                        </span>
                    {% endif %}
                    {% if product.isBestSeller %}
                        <span class="text-xs font-semibold text-white bg-amber-500 px-2.5 py-1 rounded-full">Best-seller</span>
                    {% endif %}
                    {% if product.isOnSale %}
                        <span class="text-xs font-semibold text-white bg-green-500 px-2.5 py-1 rounded-full">Promo</span>
                    {% endif %}
                </div>

                <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 leading-tight mb-3">
                    {{ product.name }}
                </h1>

                {# Note moyenne #}
                {% if avgRating is not null %}
                    <div class="flex items-center gap-2 mb-3">
                        <div class="flex text-amber-400 text-sm">
                            {% for i in 1..5 %}
                                {% if i <= avgRating|round %}★{% else %}☆{% endif %}
                            {% endfor %}
                        </div>
                        <span class="text-sm text-gray-500">
                            {{ avgRating|number_format(1) }}/5 ({{ reviews|length }} avis)
                        </span>
                    </div>
                {% endif %}

                {# Prix affiché (mis à jour par JS selon variante) #}
                <div class="text-3xl font-bold text-amber-700" id="display-price">
                    {% if product.productVariants|length > 0 %}
                        {{ product.productVariants|first.price|number_format(2, ',', ' ') }} €
                    {% else %}
                        {{ product.price|number_format(2, ',', ' ') }} €
                    {% endif %}
                </div>
            </div>

            {# Description #}
            {% if product.desciption %}
                <p class="text-gray-600 leading-relaxed text-sm">
                    {{ product.desciption }}
                </p>
            {% endif %}

            {# Sélecteur de variantes #}
            {% if product.productVariants|length > 0 %}
                <div>
                    <p class="text-sm font-semibold text-gray-700 mb-3">Choisissez votre format :</p>
                    <div class="flex flex-wrap gap-2" id="variant-selector">
                        {% for variant in product.productVariants %}
                        <label class="cursor-pointer">
                            <input type="radio" name="variant" value="{{ variant.id }}"
                                   data-price="{{ variant.price }}"
                                   data-stock="{{ variant.stock }}"
                                   class="sr-only peer"
                                   {{ loop.first ? 'checked' }}>
                            <span class="flex flex-col items-center px-4 py-3 rounded-xl border-2 border-gray-200
                                         peer-checked:border-amber-500 peer-checked:bg-amber-50
                                         hover:border-amber-300 transition-all text-sm font-medium text-gray-700
                                         peer-checked:text-amber-700">
                                <span class="font-bold">{{ variant.weight }} g</span>
                                <span class="text-xs text-gray-500 peer-checked:text-amber-600 mt-0.5">
                                    {{ variant.price|number_format(2, ',', ' ') }} €
                                </span>
                            </span>
                        </label>
                        {% endfor %}
                    </div>

                    {# Stock info #}
                    <p class="mt-3 text-xs" id="stock-info">
                        {% set firstVariant = product.productVariants|first %}
                        {% if firstVariant.stock > 5 %}
                            <span class="text-green-600 font-medium">✓ En stock</span>
                        {% elseif firstVariant.stock > 0 %}
                            <span class="text-amber-600 font-medium">⚠ Plus que {{ firstVariant.stock }} en stock</span>
                        {% else %}
                            <span class="text-red-500 font-medium">✗ Rupture de stock</span>
                        {% endif %}
                    </p>
                </div>
            {% endif %}

            {# Bouton panier #}
            <form method="POST" action="{{ path('app_cart_add') }}" id="add-to-cart-form">
                <input type="hidden" name="variant_id" id="selected-variant-id"
                       value="{{ product.productVariants|length > 0 ? product.productVariants|first.id : '' }}">
                <input type="hidden" name="quantity" value="1">

                {% set firstVariant = product.productVariants|length > 0 ? product.productVariants|first : null %}
                {% set outOfStock = firstVariant is null or firstVariant.stock == 0 %}

                <button type="submit" id="add-to-cart-btn"
                        {{ outOfStock ? 'disabled' }}
                        class="w-full py-3.5 px-6 rounded-xl font-semibold text-sm transition-all
                               {{ outOfStock
                                   ? 'bg-gray-100 text-gray-400 cursor-not-allowed'
                                   : 'bg-amber-600 hover:bg-amber-700 text-white shadow-sm hover:shadow-md active:scale-95' }}">
                    {% if outOfStock %}
                        Produit indisponible
                    {% else %}
                        Ajouter au panier
                    {% endif %}
                </button>
            </form>

            {# Conseils dégustation #}
            {% if product.tastingAdvice %}
                <div class="bg-amber-50 border border-amber-100 rounded-xl p-4">
                    <h3 class="text-sm font-semibold text-amber-800 mb-1.5 flex items-center gap-2">
                        <span>🍯</span> Conseils de dégustation
                    </h3>
                    <p class="text-sm text-amber-900 leading-relaxed">{{ product.tastingAdvice }}</p>
                </div>
            {% endif %}

            {# Allergènes #}
            {% if product.allergens %}
                <div class="text-xs text-gray-400 border-t border-gray-100 pt-4">
                    <span class="font-semibold text-gray-500">Allergènes :</span> {{ product.allergens }}
                </div>
            {% endif %}

        </div>
    </div>
</section>

{# ===== AVIS ===== #}
<section class="max-w-6xl mx-auto px-6 py-10 border-t border-gray-100">
    <h2 class="text-xl font-bold text-gray-800 mb-6">
        Avis clients
        {% if reviews|length > 0 %}
            <span class="text-base font-normal text-gray-400">({{ reviews|length }})</span>
        {% endif %}
    </h2>

    {% if reviews is empty %}
        <p class="text-gray-400 text-sm">Aucun avis pour ce produit pour l'instant.</p>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% for review in reviews %}
            <div class="bg-white rounded-xl border border-gray-200 p-5">
                <div class="flex items-start justify-between mb-3">
                    <div>
                        <p class="font-semibold text-gray-800 text-sm">
                            {{ review.user.firstName }} {{ review.user.lastName|slice(0, 1) }}.
                        </p>
                        <p class="text-xs text-gray-400 mt-0.5">{{ review.createdAt|date('d/m/Y') }}</p>
                    </div>
                    <div class="text-amber-400 text-sm">
                        {% for i in 1..5 %}
                            {% if i <= review.rating %}★{% else %}☆{% endif %}
                        {% endfor %}
                    </div>
                </div>
                {% if review.comment %}
                    <p class="text-sm text-gray-600 leading-relaxed">{{ review.comment }}</p>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    {% endif %}
</section>

<script>
(function () {
    const radios     = document.querySelectorAll('input[name="variant"]');
    const priceEl    = document.getElementById('display-price');
    const stockEl    = document.getElementById('stock-info');
    const variantIn  = document.getElementById('selected-variant-id');
    const addBtn     = document.getElementById('add-to-cart-btn');

    if (!radios.length) return;

    function updateVariant(radio) {
        const price = parseFloat(radio.dataset.price);
        const stock = parseInt(radio.dataset.stock, 10);

        // Price
        priceEl.textContent = price.toLocaleString('fr-FR', {
            minimumFractionDigits: 2, maximumFractionDigits: 2
        }) + ' €';

        // Stock label
        if (stock > 5) {
            stockEl.innerHTML = '<span class="text-green-600 font-medium">✓ En stock</span>';
        } else if (stock > 0) {
            stockEl.innerHTML = '<span class="text-amber-600 font-medium">⚠ Plus que ' + stock + ' en stock</span>';
        } else {
            stockEl.innerHTML = '<span class="text-red-500 font-medium">✗ Rupture de stock</span>';
        }

        // Cart button state
        if (addBtn) {
            if (stock === 0) {
                addBtn.disabled = true;
                addBtn.textContent = 'Produit indisponible';
                addBtn.className = addBtn.className
                    .replace('bg-amber-600 hover:bg-amber-700 text-white shadow-sm hover:shadow-md active:scale-95', '')
                    + ' bg-gray-100 text-gray-400 cursor-not-allowed';
            } else {
                addBtn.disabled = false;
                addBtn.textContent = 'Ajouter au panier';
                addBtn.className = addBtn.className
                    .replace('bg-gray-100 text-gray-400 cursor-not-allowed', '')
                    + ' bg-amber-600 hover:bg-amber-700 text-white shadow-sm hover:shadow-md active:scale-95';
            }
        }

        // Hidden input
        if (variantIn) variantIn.value = radio.value;
    }

    radios.forEach(function (radio) {
        radio.addEventListener('change', function () {
            updateVariant(this);
        });
    });

    // Init with checked radio
    const checked = document.querySelector('input[name="variant"]:checked');
    if (checked) updateVariant(checked);
})();
</script>

{% endblock %}
