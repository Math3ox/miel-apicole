{% extends 'base.html.twig' %}

{% block title %}Nos miels{% endblock %}
{% block meta_description %}Découvrez notre gamme de miels artisanaux récoltés avec passion. Filtrez par catégorie et trouvez votre miel idéal.{% endblock %}

{% block body %}

{# ===== HERO ===== #}
<section class="bg-amber-700 text-white">
    <div class="max-w-6xl mx-auto px-6 py-12">
        <h1 class="text-3xl font-bold mb-2">Nos miels</h1>
        <p class="text-amber-200 text-sm">Récoltés avec soin, directement de nos ruches à votre table.</p>
    </div>
</section>

{# ===== FILTRES ===== #}
<div class="bg-white border-b border-gray-200 sticky top-16 z-40">
    <div class="max-w-6xl mx-auto px-6 py-3 flex flex-wrap items-center gap-3 justify-between">

        {# Catégories #}
        <div class="flex flex-wrap items-center gap-2 text-sm">
            <a href="{{ path('app_shop_index', {tri: currentSort}) }}"
               class="px-3 py-1.5 rounded-full font-medium transition-colors
               {{ currentCategory is null ? 'bg-amber-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-amber-50 hover:text-amber-700' }}">
                Tous
            </a>
            {% for cat in categories %}
                <a href="{{ path('app_shop_index', {categorie: cat.slug, tri: currentSort}) }}"
                   class="px-3 py-1.5 rounded-full font-medium transition-colors
                   {{ currentCategory == cat.slug ? 'bg-amber-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-amber-50 hover:text-amber-700' }}">
                    {{ cat.name }}
                </a>
            {% endfor %}
        </div>

        {# Tri #}
        <div class="flex items-center gap-2 text-sm">
            <span class="text-gray-500 shrink-0">Trier par</span>
            <select onchange="window.location = this.value"
                    class="border border-gray-200 rounded-lg px-3 py-1.5 text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-amber-400 cursor-pointer">
                <option value="{{ path('app_shop_index', {categorie: currentCategory, tri: 'default'}) }}"
                        {{ currentSort == 'default' ? 'selected' }}>Nouveautés</option>
                <option value="{{ path('app_shop_index', {categorie: currentCategory, tri: 'price_asc'}) }}"
                        {{ currentSort == 'price_asc' ? 'selected' }}>Prix croissant</option>
                <option value="{{ path('app_shop_index', {categorie: currentCategory, tri: 'price_desc'}) }}"
                        {{ currentSort == 'price_desc' ? 'selected' }}>Prix décroissant</option>
                <option value="{{ path('app_shop_index', {categorie: currentCategory, tri: 'name'}) }}"
                        {{ currentSort == 'name' ? 'selected' }}>Nom A–Z</option>
            </select>
        </div>

    </div>
</div>

{# ===== GRILLE PRODUITS ===== #}
<section class="max-w-6xl mx-auto px-6 py-10">

    {% if products is empty %}
        <div class="text-center py-20 text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-4 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0v10l-8 4m-8-4V7m8 4v10"/>
            </svg>
            <p class="font-medium text-gray-500">Aucun produit dans cette catégorie.</p>
            <a href="{{ path('app_shop_index') }}" class="mt-3 inline-block text-amber-600 hover:underline text-sm">
                Voir tous les produits
            </a>
        </div>
    {% else %}
        <p class="text-sm text-gray-400 mb-6">{{ products|length }} produit{{ products|length != 1 ? 's' }}</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for product in products %}
            <a href="{{ path('app_shop_show', {slug: product.slug}) }}"
               class="group bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 flex flex-col">

                {# Image #}
                <div class="relative aspect-square bg-amber-50 overflow-hidden">
                    {% if product.image %}
                        <img src="/uploads/products/{{ product.image }}"
                             alt="{{ product.name }}"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                    {% else %}
                        <div class="w-full h-full flex items-center justify-center text-amber-300">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                        </div>
                    {% endif %}

                    {# Badges #}
                    <div class="absolute top-3 left-3 flex flex-col gap-1.5">
                        {% if product.isBestSeller %}
                            <span class="bg-amber-500 text-white text-xs font-semibold px-2.5 py-1 rounded-full shadow-sm">
                                Best-seller
                            </span>
                        {% endif %}
                        {% if product.isOnSale %}
                            <span class="bg-green-500 text-white text-xs font-semibold px-2.5 py-1 rounded-full shadow-sm">
                                Promo
                            </span>
                        {% endif %}
                    </div>
                </div>

                {# Contenu #}
                <div class="p-4 flex flex-col flex-1">
                    {% if product.category %}
                        <span class="text-xs font-medium text-amber-600 uppercase tracking-wide mb-1">
                            {{ product.category.name }}
                        </span>
                    {% endif %}

                    <h2 class="font-semibold text-gray-800 text-base leading-snug mb-2 group-hover:text-amber-700 transition-colors">
                        {{ product.name }}
                    </h2>

                    {% if product.desciption %}
                        <p class="text-sm text-gray-500 line-clamp-2 mb-3 flex-1">
                            {{ product.desciption }}
                        </p>
                    {% else %}
                        <div class="flex-1"></div>
                    {% endif %}

                    <div class="flex items-center justify-between mt-2">
                        <div>
                            {% set minPrice = product.price %}
                            {% for v in product.productVariants %}
                                {% if v.price < minPrice %}{% set minPrice = v.price %}{% endif %}
                            {% endfor %}
                            <span class="text-xs text-gray-400">À partir de</span>
                            <div class="font-bold text-amber-700 text-lg">
                                {{ minPrice|number_format(2, ',', ' ') }} €
                            </div>
                        </div>
                        <span class="text-xs font-medium text-amber-600 group-hover:text-amber-700 flex items-center gap-1">
                            Voir
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                            </svg>
                        </span>
                    </div>
                </div>

            </a>
            {% endfor %}
        </div>
    {% endif %}

</section>

{% endblock %}
