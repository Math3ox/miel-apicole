{% extends 'admin/layout.html.twig' %}

{% block title %}Catégories{% endblock %}
{% block page_title %}Catégories{% endblock %}

{% block admin_content %}
<div class="flex items-center justify-between mb-6">
    <p class="text-sm text-gray-500">{{ categories|length }} catégorie{{ categories|length != 1 ? 's' }}</p>
    <a href="{{ path('admin_category_create') }}"
       class="bg-amber-600 hover:bg-amber-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        Nouvelle catégorie
    </a>
</div>

{% if categories is empty %}
    <div class="bg-white rounded-xl border border-gray-200 p-12 text-center text-gray-400">
        Aucune catégorie pour l'instant.
    </div>
{% else %}
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="text-left px-4 py-3 font-medium text-gray-600">Nom</th>
                    <th class="text-left px-4 py-3 font-medium text-gray-600">Slug</th>
                    <th class="text-left px-4 py-3 font-medium text-gray-600">Description</th>
                    <th class="text-left px-4 py-3 font-medium text-gray-600">Produits</th>
                    <th class="px-4 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for category in categories %}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3 font-medium text-gray-800">{{ category.name }}</td>
                    <td class="px-4 py-3 text-gray-500 font-mono text-xs">{{ category.slug }}</td>
                    <td class="px-4 py-3 text-gray-500 max-w-xs truncate">
                        {{ category.description ?? '—' }}
                    </td>
                    <td class="px-4 py-3">
                        {% set count = category.products|length %}
                        <span class="inline-flex items-center text-xs font-medium px-2 py-0.5 rounded-full
                            {{ count > 0 ? 'bg-amber-50 text-amber-700' : 'bg-gray-100 text-gray-500' }}">
                            {{ count }} produit{{ count != 1 ? 's' }}
                        </span>
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex items-center gap-3 justify-end">
                            <a href="{{ path('admin_category_edit', {id: category.id}) }}"
                               class="text-xs font-medium text-amber-600 hover:text-amber-800 transition-colors">
                                Éditer
                            </a>
                            <form method="POST" action="{{ path('admin_category_delete', {id: category.id}) }}"
                                  onsubmit="return confirm('Supprimer « {{ category.name }} » ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_category_' ~ category.id) }}">
                                <button type="submit" class="text-xs font-medium text-red-500 hover:text-red-700 transition-colors">
                                    Supprimer
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
