<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin{% endblock %} — Miel Apicole</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🍯</text></svg>">
    <link rel="stylesheet" href="/styles/app.css">
</head>
<body class="bg-gray-100 min-h-screen flex">

    {# ===== SIDEBAR ===== #}
    <aside class="w-56 bg-amber-900 text-amber-100 flex flex-col shrink-0 min-h-screen">
        <div class="h-14 flex items-center px-5 border-b border-amber-800">
            <span class="font-bold text-white tracking-tight">Administration</span>
        </div>

        <nav class="flex-1 py-3 text-sm font-medium">
            <a href="{{ path('admin_product_index') }}"
               class="flex items-center gap-2.5 px-5 py-2.5 hover:bg-amber-800 transition-colors
               {% if app.request.attributes.get('_route') starts with 'admin_product' %}bg-amber-800 text-white{% endif %}">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0v10l-8 4m-8-4V7m8 4v10"/>
                </svg>
                Produits
            </a>
            <a href="{{ path('admin_category_index') }}"
               class="flex items-center gap-2.5 px-5 py-2.5 hover:bg-amber-800 transition-colors
               {% if app.request.attributes.get('_route') starts with 'admin_category' %}bg-amber-800 text-white{% endif %}">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                </svg>
                Catégories
            </a>
            <a href="#"
               class="flex items-center gap-2.5 px-5 py-2.5 hover:bg-amber-800 transition-colors text-amber-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                Commandes
            </a>
            <a href="#"
               class="flex items-center gap-2.5 px-5 py-2.5 hover:bg-amber-800 transition-colors text-amber-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197"/>
                </svg>
                Utilisateurs
            </a>
            <a href="#"
               class="flex items-center gap-2.5 px-5 py-2.5 hover:bg-amber-800 transition-colors text-amber-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                </svg>
                Avis
            </a>
        </nav>

        <div class="border-t border-amber-800 p-4 text-xs space-y-2">
            <a href="{{ path('app_home') }}" class="flex items-center gap-2 text-amber-300 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Retour au site
            </a>
            <a href="{{ path('app_logout') }}" class="flex items-center gap-2 text-amber-300 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                Déconnexion
            </a>
        </div>
    </aside>

    {# ===== MAIN ===== #}
    <div class="flex-1 flex flex-col min-h-screen">

        {# Top bar #}
        <header class="h-14 bg-white border-b border-gray-200 flex items-center justify-between px-6 shrink-0">
            <h1 class="font-semibold text-gray-800 text-base">{% block page_title %}{% endblock %}</h1>
            <span class="text-sm text-gray-500">
                {% if app.user %}Connecté en tant que <strong>{{ app.user.email }}</strong>{% endif %}
            </span>
        </header>

        {# Flash messages #}
        {% set flashTypes = {
            success: 'bg-green-50 border-green-400 text-green-800',
            error:   'bg-red-50 border-red-400 text-red-800',
            warning: 'bg-amber-50 border-amber-400 text-amber-800',
            info:    'bg-blue-50 border-blue-400 text-blue-800'
        } %}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="border-l-4 px-6 py-3 text-sm {{ flashTypes[type]|default('bg-gray-100 border-gray-400 text-gray-800') }}" role="alert">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <main class="flex-1 p-6">
            {% block admin_content %}{% endblock %}
        </main>
    </div>

</body>
</html>
